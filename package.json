{
  "name": "nifty-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Nifty.pm - read projects, tasks, milestones, timelogs, comments and activity",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/aws-lambda.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.2.0",
    "@vendia/serverless-express": "^4.12.6",
    "axios": "^1.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "serverless-http": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
